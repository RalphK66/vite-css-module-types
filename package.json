{
  "name": "vite-css-module-types",
  "version": "1.0.0",
  "description": "Generate .d.ts type declarations for CSS Modules in Vite 8 with Go-to-Definition support",
  "keywords": [
    "css-modules",
    "dts",
    "go-to-definition",
    "types",
    "typescript",
    "vite"
  ],
  "homepage": "https://github.com/RalphK66/vite-css-module-types#readme",
  "bugs": {
    "url": "https://github.com/RalphK66/vite-css-module-types/issues"
  },
  "license": "MIT",
  "author": "RalphK66",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RalphK66/vite-css-module-types.git"
  },
  "bin": {
    "vite-css-module-types": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "css-class-positions": "^1.0.0",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "rolldown": "^1.2.0",
    "rolldown-plugin-dts": "^0.27.10",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
